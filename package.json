{
  "name": "repotato",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Product Hunt for GitHub repos, from your terminal.",
  "bin": {
    "repotato": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx src/smoke.ts"
  },
  "dependencies": {
    "ink": "^6.0.0",
    "react": "^19.0.0",
    "sharp": "^0.34.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
